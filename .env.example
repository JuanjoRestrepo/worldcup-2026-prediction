# Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── PostgreSQL / Supabase ─────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → Database → Connection string
# Use the "Direct connection" tab (not pooler) for psycopg2 compatibility.
POSTGRES_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password

# ── dbt schema prefix ─────────────────────────────────────────────────────────
DBT_BASE_SCHEMA=analytics

# ── Feature serving ───────────────────────────────────────────────────────────
# Options: csv | postgres | dbt | auto
# Use 'csv' for local dev and Render free tier (no DB required for predictions)
PREDICTION_FEATURE_SOURCE=csv

# ── Monitoring source ─────────────────────────────────────────────────────────
# Options: auto | dbt | postgres
MONITORING_SOURCE=auto

# ── API security ──────────────────────────────────────────────────────────────
# Admin endpoints (/admin/toggle-shadow etc.) require this key in X-Admin-Key header
ADMIN_API_KEY=your-secret-admin-key-change-this

# ── API server (local) ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Model artifact path ───────────────────────────────────────────────────────
# Relative to repo root. Do not change unless you move the artifact.
MODEL_ARTIFACT_PATH=models/match_predictor.joblib

# ── Football-Data API (optional — for live data ingestion only) ───────────────
FOOTBALL_API_KEY=your-football-data-api-key
